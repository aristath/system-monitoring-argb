# Optional sysmon runtime config. Copy values you need into
# ~/.config/sysmon/config.env, or point SYSMON_CONFIG at another file.

openrgb_host=127.0.0.1
openrgb_port=6742

# Device can be an OpenRGB controller index or a case-insensitive name match.
openrgb_device=ASRock

# Zone names are matched case-insensitively against OpenRGB zone names.
aio_zone=Addressable Header 3/Audio
aio_leds=36
cpu_temp_zone=PCB
gpu_temp_zone=IO Cover
